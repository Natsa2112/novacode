{
  "name": "novacode.com.ar",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=9.6.5"
  },
  "scripts": {
    "dev": "wrangler types && astro dev",
    "start": "wrangler types && astro dev",
    "build": "wrangler types && astro check && astro build",
    "preview": "wrangler types && astro preview",
    "astro": "astro",
    "cf:types": "wrangler types",
    "cf:deploy": "wrangler deploy",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "lint:staged": "eslint --no-warn-ignored --max-warnings 0",
    "typecheck": "astro check",
    "format": "prettier --write \"**/*.{astro,ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{astro,ts,tsx,js,jsx,json,md,yml,yaml}\"",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{astro,ts,tsx,js,jsx}": [
      "prettier --check",
      "npm run lint:staged --"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --check"
    ]
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.6.0",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/inter": "^5.2.8",
    "astro": "^6.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.1",
    "eslint": "^10.4.1",
    "eslint-plugin-astro": "^1.7.0",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "wrangler": "^4.97.0"
  }
}
