---
import PlanCard from './PlanCard.astro';
import { plans } from '../config/site';
---

<section id="planes" class="plans-section">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title">Planes a Tu Medida.</h2>
      <p class="section-subtitle">
        Entendemos que cada empresa es única, por eso ofrecemos planes flexibles que se adaptan a
        tus necesidades específicas. Desde emprendedores hasta grandes compañías, tenemos la
        solución ideal para ti.
      </p>
    </header>

    <div class="trust-bar">
      <span class="trust-bar__item">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        Soporte 24/7
      </span>
      <span class="trust-bar__item">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
        </svg>
        Resultados Garantizados
      </span>
      <span class="trust-bar__item">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <polyline points="12 6 12 12 16 14"></polyline>
        </svg>
        Cancelá cuando quieras
      </span>
    </div>

    <div class="plans-grid">
      {plans.map((plan, index) => <PlanCard plan={plan} index={index} />)}
    </div>
  </div>
</section>

<style>
  .plans-section {
    position: relative;
  }

  #planes {
    background:
      radial-gradient(ellipse 50% 40% at 80% 30%, rgba(6, 182, 212, 0.03) 0%, transparent 60%),
      radial-gradient(ellipse 40% 30% at 20% 70%, rgba(99, 102, 241, 0.02) 0%, transparent 50%);
  }

  .section-header {
    position: relative;
    z-index: 1;
  }

  .trust-bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-8);
    margin-bottom: var(--space-10);
    position: relative;
    z-index: 1;
  }

  .trust-bar__item {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
    color: var(--color-text-secondary);
    white-space: nowrap;
  }

  .trust-bar__item svg {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: stretch;
    position: relative;
    z-index: 1;
  }

  @media (max-width: 1024px) {
    .trust-bar {
      flex-direction: column;
      gap: var(--space-3);
      align-items: center;
    }

    .plans-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin: 0 auto;
    }
  }
</style>
