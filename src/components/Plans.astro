---
import PlanCard from './PlanCard.astro';
import { plans } from '../config/site';
---

<section id="planes" class="section plans-section">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title">Planes a Tu Medida.</h2>
      <p class="section-subtitle">
        Entendemos que cada empresa es única, por eso ofrecemos planes flexibles que se adaptan a
        tus necesidades específicas. Desde emprendedores hasta grandes compañías, tenemos la
        solución ideal para ti.
      </p>
    </header>

    <div class="plans-grid">
      {plans.map((plan, index) => <PlanCard plan={plan} index={index} />)}
    </div>
  </div>
</section>

<style>
  /* ---------- Section decoration ---------- */
  .section {
    position: relative;
  }

  #planes::before {
    content: '';
    position: absolute;
    top: 30%;
    right: -10%;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, var(--color-accent-2) 0%, transparent 70%);
    opacity: 0.06;
    filter: blur(90px);
    pointer-events: none;
    z-index: 0;
  }

  .section-header,
  .plans-grid {
    position: relative;
    z-index: 1;
  }

  /* ---------- Grid ---------- */
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
    align-items: stretch;
  }

  @media (max-width: 1024px) {
    .plans-grid {
      grid-template-columns: 1fr;
      max-width: 460px;
      margin: 0 auto;
    }
  }

  /* ---------- Card base ---------- */
  :global(.plan-card) {
    position: relative;
    display: flex;
    flex-direction: column;
    padding: var(--space-7) var(--space-7) var(--space-6);
    background: linear-gradient(180deg, var(--color-bg-surface) 0%, var(--color-bg-base) 100%);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    overflow: hidden;
    isolation: isolate;
    transition:
      transform var(--duration-slow) var(--ease-out),
      border-color var(--duration-slow) var(--ease-out),
      box-shadow var(--duration-slow) var(--ease-out);
  }

  :global(.plan-card[data-tier='1']) {
    --tier-1: #94a3b8;
    --tier-2: #64748b;
    --tier-glow: rgba(148, 163, 184, 0.25);
    --tier-soft: rgba(148, 163, 184, 0.12);
  }

  :global(.plan-card[data-tier='2']) {
    --tier-1: #6366f1;
    --tier-2: #06b6d4;
    --tier-glow: rgba(99, 102, 241, 0.5);
    --tier-soft: rgba(99, 102, 241, 0.15);
  }

  :global(.plan-card[data-tier='3']) {
    --tier-1: #f59e0b;
    --tier-2: #ec4899;
    --tier-glow: rgba(245, 158, 11, 0.4);
    --tier-soft: rgba(245, 158, 11, 0.15);
  }

  /* ---------- Hover lift ---------- */
  :global(.plan-card:hover) {
    transform: translateY(-6px);
    border-color: transparent;
    box-shadow: 0 24px 48px -16px rgba(0, 0, 0, 0.5);
  }

  /* ---------- Featured: elevated, glowing ---------- */
  :global(.plan-card.featured) {
    background:
      radial-gradient(ellipse 80% 50% at 50% 0%, var(--tier-soft) 0%, transparent 70%),
      linear-gradient(180deg, var(--color-bg-surface) 0%, var(--color-bg-base) 100%);
    box-shadow:
      0 24px 64px -16px var(--tier-glow),
      0 0 0 1px var(--tier-1);
  }

  :global(.plan-card.featured:hover) {
    transform: translateY(-10px);
    box-shadow:
      0 32px 72px -16px var(--tier-glow),
      0 0 0 1px var(--tier-1);
  }

  /* ---------- Gradient border layer ---------- */
  :global(.plan-card__border) {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1.5px;
    background: linear-gradient(135deg, var(--tier-1), var(--tier-2));
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
    pointer-events: none;
    z-index: 1;
  }

  :global(.plan-card:hover .plan-card__border) {
    opacity: 0.7;
  }

  :global(.plan-card.featured .plan-card__border) {
    opacity: 0.9;
  }

  /* ---------- Background grid pattern ---------- */
  :global(.plan-card__grid) {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--tier-1) 1px, transparent 1px),
      linear-gradient(90deg, var(--tier-1) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0;
    mask-image: radial-gradient(ellipse 60% 50% at 50% 0%, #000 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 60% 50% at 50% 0%, #000 0%, transparent 70%);
    transition: opacity var(--duration-slow) var(--ease-out);
    pointer-events: none;
    z-index: 0;
  }

  :global(.plan-card.featured .plan-card__grid) {
    opacity: 0.05;
  }

  :global(.plan-card:hover .plan-card__grid) {
    opacity: 0.06;
  }

  /* ---------- Corner brackets ---------- */
  :global(.plan-card__bracket) {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--tier-1);
    opacity: 0.4;
    transition: opacity var(--duration-base) var(--ease-out);
    pointer-events: none;
    z-index: 3;
  }

  :global(.plan-card__bracket--tl) {
    top: 10px;
    left: 10px;
    border-right: none;
    border-bottom: none;
  }

  :global(.plan-card__bracket--br) {
    bottom: 10px;
    right: 10px;
    border-left: none;
    border-top: none;
  }

  :global(.plan-card:hover .plan-card__bracket),
  :global(.plan-card.featured .plan-card__bracket) {
    opacity: 0.9;
  }

  /* ---------- Badge (featured only) ---------- */
  :global(.plan-badge) {
    position: absolute;
    top: -1px;
    right: -1px;
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    background: linear-gradient(135deg, var(--tier-1), var(--tier-2));
    color: var(--color-text-on-accent);
    padding: var(--space-2) var(--space-4);
    border-bottom-left-radius: var(--radius-lg);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    box-shadow: 0 8px 24px -8px var(--tier-glow);
    z-index: 4;
  }

  :global(.plan-badge__dot) {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fff;
    box-shadow: 0 0 8px #fff;
    animation: badge-pulse 1.6s ease-in-out infinite;
  }

  @keyframes badge-pulse {
    0%,
    100% {
      opacity: 1;
    }
    50% {
      opacity: 0.4;
    }
  }

  /* ---------- Header: tier + code ---------- */
  :global(.plan-card__head) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-5);
    position: relative;
    z-index: 2;
  }

  :global(.plan-card__tier) {
    display: inline-flex;
    align-items: flex-end;
    gap: 3px;
    height: 14px;
  }

  :global(.plan-card__tier-bar) {
    width: 4px;
    background: var(--color-border-default);
    border-radius: 1px;
    transition: background var(--duration-base) var(--ease-out);
  }

  :global(.plan-card__tier-bar:nth-child(1)) {
    height: 6px;
  }
  :global(.plan-card__tier-bar:nth-child(2)) {
    height: 10px;
  }
  :global(.plan-card__tier-bar:nth-child(3)) {
    height: 14px;
  }

  :global(.plan-card__tier-bar.active) {
    background: linear-gradient(180deg, var(--tier-1), var(--tier-2));
    box-shadow: 0 0 6px var(--tier-soft);
  }

  :global(.plan-card__code) {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-text-tertiary);
    text-transform: uppercase;
  }

  /* ---------- Typography ---------- */
  :global(.plan-card__name) {
    font-size: var(--text-2xl);
    font-weight: 800;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-2);
    letter-spacing: -0.02em;
    line-height: 1.15;
    position: relative;
    z-index: 2;
  }

  :global(.plan-card.featured .plan-card__name) {
    background: linear-gradient(135deg, var(--tier-1), var(--tier-2));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  :global(.plan-card__desc) {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin: 0;
    min-height: 2.5em;
    position: relative;
    z-index: 2;
  }

  /* ---------- Divider ---------- */
  :global(.plan-card__divider) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-6) 0;
    position: relative;
    z-index: 2;
  }

  :global(.plan-card__divider-line) {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-border-subtle) 30%,
      var(--tier-1) 100%
    );
    opacity: 0.6;
  }

  :global(.plan-card__divider-glyph) {
    color: var(--tier-1);
    font-size: 8px;
    opacity: 0.7;
  }

  /* ---------- Features ---------- */
  :global(.plan-card__features) {
    list-style: none;
    margin: 0 0 var(--space-7);
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    position: relative;
    z-index: 2;
  }

  :global(.plan-card__features li) {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  :global(.plan-card__check) {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--tier-1);
    background: var(--tier-soft);
    border: 1px solid transparent;
    transition:
      transform var(--duration-base) var(--ease-spring),
      background var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
  }

  :global(.plan-card__check svg) {
    width: 12px;
    height: 12px;
  }

  :global(.plan-card:hover .plan-card__check) {
    transform: scale(1.1);
    background: var(--color-bg-elevated);
    border-color: var(--tier-1);
  }

  /* ---------- CTA ---------- */
  :global(.plan-card__cta) {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-3) var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
    text-decoration: none;
    position: relative;
    z-index: 2;
    transition:
      transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out);
  }

  :global(.plan-card__cta svg) {
    width: 16px;
    height: 16px;
    transition: transform var(--duration-base) var(--ease-out);
  }

  :global(.plan-card__cta--primary) {
    color: var(--color-text-on-accent);
    background: linear-gradient(135deg, var(--tier-1), var(--tier-2));
    box-shadow: 0 8px 24px -8px var(--tier-glow);
  }

  :global(.plan-card__cta--primary:hover) {
    transform: translateY(-2px);
    box-shadow: 0 12px 32px -8px var(--tier-glow);
  }

  :global(.plan-card__cta--primary:hover svg) {
    transform: translateX(3px);
  }

  :global(.plan-card__cta--outline) {
    color: var(--color-text-primary);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-default);
  }

  :global(.plan-card__cta--outline:hover) {
    transform: translateY(-2px);
    border-color: var(--tier-1);
    background: var(--color-bg-surface);
    color: var(--tier-1);
  }

  :global(.plan-card__cta--outline:hover svg) {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.plan-card),
    :global(.plan-card *),
    :global(.plan-card__border),
    :global(.plan-card__grid),
    :global(.plan-card__bracket),
    :global(.plan-card__tier-bar),
    :global(.plan-card__check),
    :global(.plan-card__cta),
    :global(.plan-card__cta svg),
    :global(.plan-badge__dot) {
      transition: none;
      animation: none;
    }
    :global(.plan-card:hover),
    :global(.plan-card__cta:hover) {
      transform: none;
    }
  }
</style>
