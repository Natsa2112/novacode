---
import PlanCard from './PlanCard.astro';
import { plans } from '../config/site';
---

<section id="planes" class="section">
  <div class="container">
    <h2 class="section-title">Planes a Tu Medida.</h2>
    <p class="section-subtitle">
      Entendemos que cada empresa es única, por eso ofrecemos planes flexibles que se adaptan
      a tus necesidades específicas. Desde emprendedores hasta grandes compañías, tenemos la
      solución ideal para ti.
    </p>

    <div class="plans-grid">
      {plans.map((plan) => <PlanCard plan={plan} />)}
    </div>
  </div>
</section>

<style>
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin-top: 3rem;
  }

  .plan-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 2rem;
    text-align: center;
    transition:
      transform 0.3s ease,
      box-shadow 0.3s ease;
    position: relative;
    backdrop-filter: blur(10px);
  }

  .plan-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
  }

  .plan-card.featured {
    background: linear-gradient(
      135deg,
      rgba(185, 120, 204, 0.1) 0%,
      rgba(135, 218, 74, 0.1) 100%
    );
    border: 2px solid var(--secondary);
    transform: scale(1.05);
  }

  .plan-card.featured:hover {
    transform: scale(1.05) translateY(-10px);
  }

  .plan-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--secondary-strong);
    color: white;
    padding: 0.5rem 1.5rem;
    border-radius: 20px;
    font-size: 0.9rem;
    font-weight: 600;
  }

  .plan-header {
    margin-bottom: 2rem;
  }

  .plan-header :global(h3) {
    font-size: 1.8rem;
    margin-bottom: 1rem;
    background: linear-gradient(135deg, var(--text-primary), var(--secondary));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .plan-description {
    color: var(--text-secondary);
    font-size: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .features {
    list-style: none;
    margin: 0;
    padding: 0;
    margin-bottom: 2rem;
  }

  .features :global(li) {
    color: var(--text-secondary);
    padding: 0.8rem 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
  }

  .features :global(li:last-child) {
    border-bottom: none;
  }

  .btn {
    display: inline-block;
    padding: 1rem 2rem;
    border-radius: 50px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.3s ease;
    width: 100%;
  }

  .btn-primary {
    background: var(--secondary-strong);
    color: white;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(185, 120, 204, 0.4);
  }

  .btn-outline {
    background: transparent;
    color: var(--text-primary);
    border: 2px solid var(--secondary);
  }

  .btn-outline:hover {
    background: var(--secondary-strong);
    color: white;
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .plans-grid {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .plan-card.featured {
      transform: scale(1);
    }

    .plan-card.featured:hover {
      transform: translateY(-10px);
    }
  }
</style>
