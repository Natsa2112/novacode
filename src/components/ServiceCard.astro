---
import type { Service } from '../types';
import Icon from './Icon.astro';

interface Props {
  service: Service;
  index: number;
}

const { service, index } = Astro.props;
const href = '#contacto';
const tierLevel = index + 1;
---

<article class="service-card" data-accent={service.icon} data-tier={tierLevel}>
  <div class="service-card__icon">
    <Icon name={service.icon} size={32} strokeWidth={1.8} />
  </div>

  <h3 class="service-card__title">{service.title}</h3>
  <p class="service-card__desc">{service.description}</p>

  <ul class="service-card__features">
    {
      service.features.map((f) => (
        <li>
          <svg class="service-card__check" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <path
              d="M4.5 10.5l3 3 8-8"
              stroke="currentColor"
              stroke-width="2.4"
              stroke-linecap="round"
              stroke-linejoin="round"
            />
          </svg>
          <span>{f}</span>
        </li>
      ))
    }
  </ul>

  <a class="service-card__cta" href={href} aria-label={`Conocer más sobre ${service.title}`}>
    <span>Conocer más</span>
    <svg width="16" height="16" viewBox="0 0 20 20" fill="none" aria-hidden="true">
      <path
        d="M4 10h12m0 0l-4-4m4 4l-4 4"
        stroke="currentColor"
        stroke-width="1.8"
        stroke-linecap="round"
        stroke-linejoin="round"></path>
    </svg>
  </a>
</article>

<style>
  .service-card[data-accent='megaphone'] {
    --accent-1: #6366f1;
    --accent-soft: rgba(99, 102, 241, 0.1);
    --accent-border: rgba(99, 102, 241, 0.3);
  }

  .service-card[data-accent='code'] {
    --accent-1: #06b6d4;
    --accent-soft: rgba(6, 182, 212, 0.1);
    --accent-border: rgba(6, 182, 212, 0.3);
  }

  .service-card[data-accent='palette'] {
    --accent-1: #ec4899;
    --accent-soft: rgba(236, 72, 153, 0.1);
    --accent-border: rgba(236, 72, 153, 0.3);
  }

  .service-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--space-10);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    transition:
      transform var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out);
    position: relative;
    gap: var(--space-6);
  }

  .service-card:hover {
    transform: translateY(-3px);
    border-color: var(--accent-1);
    background: linear-gradient(180deg, var(--accent-soft) 0%, var(--color-bg-surface) 60%);
    box-shadow:
      0 0 0 1px var(--accent-1),
      0 12px 32px -16px var(--accent-1);
  }

  .service-card__icon {
    align-self: center;
    width: 72px;
    height: 72px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    color: var(--accent-1);
    background: var(--accent-soft);
    transition:
      background var(--duration-base) var(--ease-out),
      color var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .service-card:hover .service-card__icon {
    background: var(--accent-1);
    color: #fff;
    transform: scale(1.05);
  }

  .service-card__title {
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0;
    letter-spacing: -0.02em;
    line-height: 1.2;
    transition: color var(--duration-base) var(--ease-out);
  }

  .service-card:hover .service-card__title {
    color: var(--accent-1);
  }

  .service-card__desc {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-relaxed);
    margin: 0;
    max-width: 38ch;
  }

  .service-card__features {
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: var(--card-gap-row);
    align-items: flex-start;
    width: 100%;
  }

  .service-card__features li {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
    text-align: left;
  }

  .service-card__check {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    margin-top: 2px;
    color: var(--accent-1);
  }

  .service-card__cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: var(--space-4) var(--space-5);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    font-weight: 600;
    text-decoration: none;
    color: var(--color-text-primary);
    background: transparent;
    border: 1px solid var(--color-border-default);
    gap: var(--space-1);
    transition:
      transform var(--duration-base) var(--ease-out),
      box-shadow var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      color var(--duration-base) var(--ease-out);
  }

  .service-card__cta svg {
    transition: transform var(--duration-base) var(--ease-out);
  }

  .service-card:hover .service-card__cta {
    transform: translateY(-2px);
    border-color: var(--accent-1);
    color: #fff;
    background: var(--accent-1);
  }

  .service-card:hover .service-card__cta svg {
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    .service-card,
    .service-card *,
    .service-card__icon,
    .service-card__title,
    .service-card__cta,
    .service-card__cta svg {
      transition: none;
    }
    .service-card:hover,
    .service-card:hover .service-card__icon,
    .service-card:hover .service-card__cta {
      transform: none;
    }
  }
</style>
