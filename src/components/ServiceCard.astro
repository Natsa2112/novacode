---
import type { Service } from '../types';
import Icon from './Icon.astro';

interface Props {
  service: Service;
  index: number;
}

const { service, index } = Astro.props;
const number = String(index + 1).padStart(2, '0');
const href = '#contacto';
---

<article class="service-card" data-accent={service.icon}>
  <span class="service-card__border" aria-hidden="true"></span>
  <span class="service-card__grid" aria-hidden="true"></span>
  <span class="service-card__shine" aria-hidden="true"></span>

  <header class="service-card__head">
    <div class="service-card__icon">
      <span class="service-card__ring" aria-hidden="true"></span>
      <span class="service-card__icon-glow" aria-hidden="true"></span>
      <Icon name={service.icon} size={26} />
      <span class="service-card__pulse" aria-hidden="true"></span>
    </div>
    <span class="service-card__number" aria-hidden="true">{number}</span>
  </header>

  <h3 class="service-card__title">{service.title}</h3>
  <p class="service-card__desc">{service.description}</p>

  <div class="service-card__divider" aria-hidden="true"></div>

  <ul class="service-card__features">
    {
      service.features.map((f) => (
        <li>
          <span class="service-card__check" aria-hidden="true">
            <svg viewBox="0 0 20 20" fill="none">
              <path
                d="M4.5 10.5l3 3 8-8"
                stroke="currentColor"
                stroke-width="2.4"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <span>{f}</span>
        </li>
      ))
    }
  </ul>

  <a class="service-card__cta" href={href} aria-label={`Conocer más sobre ${service.title}`}>
    <span class="service-card__cta-shine" aria-hidden="true"></span>
    <span class="service-card__cta-label">Conocer más</span>
    <span class="service-card__cta-arrow" aria-hidden="true">
      <svg viewBox="0 0 20 20" fill="none">
        <path
          d="M4 10h12m0 0l-4-4m4 4l-4 4"
          stroke="currentColor"
          stroke-width="1.8"
          stroke-linecap="round"
          stroke-linejoin="round"></path>
      </svg>
    </span>
  </a>
</article>
