---
import InfoCard from './InfoCard.astro';
import FormField from './FormField.astro';
import Icon from './Icon.astro';
import { contactInfo, socials } from '../config/site';
---

<section id="contacto" class="section">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title">Conecta con Nosotros</h2>
      <p class="section-subtitle">
        ¿Listo para impulsar tu presencia digital? Contáctanos y descubre cómo podemos ayudarte a
        alcanzar tus objetivos.
      </p>
    </header>

    <div class="contact-grid">
      <aside class="contact-info">
        {contactInfo.map((info) => <InfoCard info={info} />)}

        <div class="social-block">
          <h3 class="social-block__title">Seguinos</h3>
          <div class="social-links">
            {
              socials.map((s) => (
                <a
                  href={s.href}
                  class="social-link"
                  aria-label={s.name}
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  <Icon name={s.icon} size={20} />
                </a>
              ))
            }
          </div>
        </div>
      </aside>

      <form class="contact-form" id="contactForm" action="/api/contact" method="POST" novalidate>
        <FormField name="nombre" label="Nombre">
          <input
            type="text"
            id="nombre"
            name="nombre"
            class="input"
            placeholder="Tu nombre"
            required
            aria-describedby="nombre-error"
          />
        </FormField>
        <FormField name="email" label="Email">
          <input
            type="email"
            id="email"
            name="email"
            class="input"
            placeholder="tu@email.com"
            required
            aria-describedby="email-error"
          />
        </FormField>
        <FormField name="telefono" label="Teléfono">
          <input
            type="tel"
            id="telefono"
            name="telefono"
            class="input"
            placeholder="+54 11 0000-0000"
            required
            aria-describedby="telefono-error"
          />
        </FormField>
        <FormField name="servicio" label="Servicio">
          <select id="servicio" name="servicio" class="select" required aria-describedby="servicio-error">
            <option value="" disabled selected hidden>Elegí un servicio</option>
            <option value="web">Desarrollo Web</option>
            <option value="marketing">Marketing Digital</option>
            <option value="ecommerce">E-commerce</option>
            <option value="otro">Otro</option>
          </select>
        </FormField>
        <FormField name="mensaje" label="Mensaje">
          <textarea
            id="mensaje"
            name="mensaje"
            class="textarea"
            placeholder="Contanos en qué podemos ayudarte"
            required
            aria-describedby="mensaje-error"></textarea>
        </FormField>
        <button type="submit" class="btn btn--primary btn--lg btn--full" id="submitBtn">
          <span id="submitText">Enviar Mensaje</span>
          <span id="submitSpinner" class="btn-spinner" aria-hidden="true" hidden>
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <circle cx="12" cy="12" r="10" stroke-dasharray="32" stroke-dashoffset="32" />
            </svg>
          </span>
        </button>
        <div id="formAlert" class="form-alert" role="alert" hidden></div>
      </form>
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    const form = document.getElementById('contactForm');
    if (!form) return;

    const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const PHONE_RE = /^[\d\s+\-()]{6,}$/;
    const SERVICIOS = new Set(['web', 'marketing', 'ecommerce', 'otro']);

    const getFieldErrors = (data) => {
      const errors = {};
      const nombre = (data.nombre ?? '').trim();
      const email = (data.email ?? '').trim();
      const telefono = (data.telefono ?? '').trim();
      const servicio = (data.servicio ?? '').trim();
      const mensaje = (data.mensaje ?? '').trim();

      if (nombre.length < 2 || nombre.length > 100)
        errors.nombre = 'Ingresá tu nombre (2-100 caracteres).';
      if (!EMAIL_RE.test(email) || email.length > 200) errors.email = 'Email inválido.';
      if (!PHONE_RE.test(telefono) || telefono.length > 30)
        errors.telefono = 'Teléfono inválido.';
      if (!SERVICIOS.has(servicio)) errors.servicio = 'Elegí un servicio válido.';
      if (mensaje.length < 3 || mensaje.length > 2000)
        errors.mensaje = 'El mensaje debe tener entre 3 y 2000 caracteres.';

      return errors;
    };

    const showFieldError = (name, message) => {
      const group = document.querySelector(`[data-field="${name}"]`);
      if (!group) return;
      let errorEl = group.querySelector('.form-error');
      if (!errorEl) {
        errorEl = document.createElement('p');
        errorEl.className = 'form-error';
        errorEl.id = `${name}-error`;
        errorEl.setAttribute('role', 'alert');
        const slot = group.querySelector(':scope > :not(.form-label)') || group.lastElementChild;
        if (slot) slot.after(errorEl);
        else group.appendChild(errorEl);
      }
      errorEl.textContent = message;

      const input = group.querySelector('input, select, textarea');
      if (input) {
        input.setAttribute('aria-invalid', 'true');
        input.setAttribute('aria-describedby', `${name}-error`);
      }
    };

    const clearFieldError = (name) => {
      const group = document.querySelector(`[data-field="${name}"]`);
      if (!group) return;
      const errorEl = group.querySelector('.form-error');
      if (errorEl) errorEl.remove();

      const input = group.querySelector('input, select, textarea');
      if (input) {
        input.removeAttribute('aria-invalid');
        const desc = input.getAttribute('aria-describedby');
        if (desc === `${name}-error`) input.removeAttribute('aria-describedby');
      }
    };

    const clearAllErrors = () => {
      document.querySelectorAll('.form-error').forEach((el) => el.remove());
      form.querySelectorAll('[aria-invalid]').forEach((el) => el.removeAttribute('aria-invalid'));
    };

    const showAlert = (message, type = 'error') => {
      const alert = document.getElementById('formAlert');
      if (!alert) return;
      alert.textContent = message;
      alert.className = `form-alert form-alert--${type}`;
      alert.hidden = false;
    };

    const hideAlert = () => {
      const alert = document.getElementById('formAlert');
      if (alert) {
        alert.hidden = true;
        alert.textContent = '';
      }
    };

    const setLoading = (loading) => {
      const btn = document.getElementById('submitBtn');
      const text = document.getElementById('submitText');
      const spinner = document.getElementById('submitSpinner');
      if (!btn) return;
      btn.disabled = loading;
      if (text) text.hidden = loading;
      if (spinner) spinner.hidden = !loading;
    };

    const serializeForm = (formEl) => {
      const data = {};
      const fd = new FormData(formEl);
      for (const [key, value] of fd.entries()) {
        data[key] = value;
      }
      return data;
    };

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideAlert();
      clearAllErrors();

      const data = serializeForm(form);
      const errors = getFieldErrors(data);

      if (Object.keys(errors).length > 0) {
        Object.entries(errors).forEach(([field, msg]) => showFieldError(field, msg));
        const firstError = form.querySelector('[aria-invalid="true"]');
        if (firstError) firstError.focus();
        return;
      }

      setLoading(true);

      try {
        const res = await fetch('/api/contact', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (res.ok) {
          window.location.href = '/gracias';
          return;
        }

        if (res.status === 422) {
          const json = await res.json();
          if (json.errors) {
            Object.entries(json.errors).forEach(([field, msg]) => showFieldError(field, msg));
          } else {
            showAlert('Ocurrió un error. Intentalo de nuevo más tarde.');
          }
        } else {
          showAlert('Ocurrió un error. Intentalo de nuevo más tarde.');
        }
      } catch {
        showAlert('Error de conexión. Verificá tu conexión a internet.');
      } finally {
        setLoading(false);
      }
    });

    form.querySelectorAll('input, select, textarea').forEach((input) => {
      input.addEventListener('input', () => {
        const name = input.name;
        if (name) {
          clearFieldError(name);
          hideAlert();
        }
      });
    });
  })();
</script>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: var(--space-8);
    align-items: start;
  }

  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .social-block {
    margin-top: var(--space-2);
    padding: var(--space-5);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-lg);
  }

  .social-block__title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-4);
  }

  .social-links {
    display: flex;
    gap: var(--space-2);
  }

  .social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    color: var(--color-text-secondary);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    transition:
      color var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .social-link:hover {
    color: var(--color-text-primary);
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .contact-form {
    padding: var(--space-8);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    box-shadow: var(--shadow-lg);
  }

  .form-alert {
    margin-top: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    font-size: var(--text-sm);
    line-height: var(--leading-normal);
  }

  .form-alert--error {
    background: rgba(239, 68, 68, 0.1);
    border: 1px solid rgba(239, 68, 68, 0.3);
    color: #ef4444;
  }

  .btn-spinner svg {
    animation: spin 0.8s linear infinite;
  }

  .btn-spinner circle {
    animation: dash 1.4s ease-in-out infinite;
    stroke-linecap: round;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  @keyframes dash {
    0% { stroke-dashoffset: 32; }
    50% { stroke-dashoffset: 8; transform: rotate(135deg); }
    100% { stroke-dashoffset: 32; transform: rotate(360deg); }
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 768px) {
    .contact-form {
      padding: var(--space-5);
    }

    .social-links {
      justify-content: center;
    }
  }
</style>
