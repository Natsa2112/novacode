---
import Icon from './Icon.astro';
import { site, socials, sections, legalLinks, contactInfo } from '../config/site';
---

<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <a href="/" class="footer-logo" aria-label={`${site.name} - Inicio`}>
          <span class="footer-logo__mark" aria-hidden="true"></span>
          <span class="footer-logo__text">{site.name}</span>
        </a>
        <p class="footer-brand__desc">
          Agencia digital especializada en desarrollo web, marketing digital y diseño. Soluciones a
          medida para hacer crecer tu negocio.
        </p>
        <div class="footer-social" aria-label="Redes sociales">
          {
            socials.map((s) => (
              <a
                href={s.href}
                class="footer-social__link"
                aria-label={s.name}
                target="_blank"
                rel="noopener noreferrer"
              >
                <Icon name={s.icon} size={18} />
              </a>
            ))
          }
        </div>
      </div>

      <nav class="footer-nav" aria-label="Enlaces del sitio">
        <h3 class="footer-nav__title">Navegación</h3>
        <ul>
          {
            sections.map((s) => (
              <li>
                <a href={s.href}>{s.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>

      <div class="footer-contact">
        <h3 class="footer-nav__title">Contacto</h3>
        <ul class="footer-contact__list">
          {
            contactInfo.map((info) => (
              <li class="footer-contact__item">
                <Icon name={info.icon} size={16} class="footer-contact__icon" />
                <span>{info.description}</span>
              </li>
            ))
          }
        </ul>
      </div>

      <nav class="footer-nav" aria-label="Enlaces legales">
        <h3 class="footer-nav__title">Legal</h3>
        <ul>
          {
            legalLinks.map((l) => (
              <li>
                <a href={l.href}>{l.label}</a>
              </li>
            ))
          }
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>&copy; {new Date().getFullYear()} {site.name}. Todos los derechos reservados.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    margin-top: var(--space-16);
    padding: var(--space-16) 0 var(--space-8);
    background: linear-gradient(180deg, transparent 0%, var(--color-bg-surface) 30%);
    border-top: 1px solid var(--color-border-subtle);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr;
    gap: var(--space-10);
    margin-bottom: var(--space-10);
  }

  .footer-brand__desc {
    margin-top: var(--space-4);
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    max-width: 360px;
    font-size: var(--text-sm);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: 'Effort', sans-serif;
    font-size: var(--text-5xl);
    font-weight: 900;
    letter-spacing: -0.02em;
    color: var(--color-text-primary);
    text-decoration: none;
  }

  .footer-logo__mark {
    width: 10px;
    height: 10px;
    border-radius: 3px;
    background: var(--gradient-accent);
    box-shadow: var(--shadow-glow-accent);
  }

  .footer-social {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-5);
  }

  .footer-social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-text-secondary);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    transition:
      color var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      transform var(--duration-base) var(--ease-out);
  }

  .footer-social__link:hover {
    color: var(--color-text-primary);
    background: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .footer-nav__title {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--color-text-primary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-4);
  }

  .footer-nav ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-nav a {
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    text-decoration: none;
    transition: color var(--duration-base) var(--ease-out);
  }

  .footer-nav a:hover {
    color: var(--color-text-primary);
  }

  .footer-contact__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .footer-contact__item {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
  }

  .footer-contact__icon {
    color: var(--color-accent);
    flex-shrink: 0;
  }

  .footer-bottom {
    padding-top: var(--space-6);
    border-top: 1px solid var(--color-border-subtle);
    text-align: center;
  }

  .footer-bottom p {
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
  }

  @media (max-width: 768px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-8);
    }

    .footer-brand {
      grid-column: 1 / -1;
    }

    .footer-brand__desc {
      max-width: 100%;
    }
  }
</style>
