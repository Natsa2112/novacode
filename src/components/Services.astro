---
import ServiceCard from './ServiceCard.astro';
import { services } from '../config/site';
---

<section id="servicios" class="section">
  <div class="container">
    <h2 class="section-title">Soluciones Digitales para Cada Necesidad</h2>
    <p class="section-subtitle">
      Nosotros cubrimos todos los frentes de la presencia digital. Desde el desarrollo de
      páginas web profesionales hasta campañas de marketing digital de alto impacto, nuestros
      servicios están diseñados para maximizar tu crecimiento.
    </p>

    <div class="services-grid">
      {services.map((service) => <ServiceCard service={service} />)}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    margin-top: 3rem;
  }

  .service-icon {
    width: 48px;
    height: 48px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1rem;
    color: var(--text-primary);
  }

  .service-icon.chart {
    background: var(--secondary);
  }

  .service-icon.monitor {
    background: var(--accent);
  }

  .service-icon.sparkle {
    background: var(--highlight);
    color: var(--primary);
  }

  .service-card :global(h3) {
    font-size: 1.5rem;
    color: var(--text-primary);
  }

  .service-card :global(p) {
    color: var(--text-secondary);
    margin-bottom: 1rem;
  }

  .service-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .service-features :global(li) {
    color: var(--text-secondary);
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .service-features :global(li::before) {
    content: '•';
    color: var(--secondary);
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
