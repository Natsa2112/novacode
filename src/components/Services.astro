---
import ServiceCard from './ServiceCard.astro';
import { services } from '../config/site';
---

<section id="servicios" class="section">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title">Soluciones Digitales para Cada Necesidad</h2>
      <p class="section-subtitle">
        Nosotros cubrimos todos los frentes de la presencia digital. Desde el desarrollo de páginas
        web profesionales hasta campañas de marketing digital de alto impacto, nuestros servicios
        están diseñados para maximizar tu crecimiento.
      </p>
    </header>

    <div class="services-grid">
      {services.map((service) => <ServiceCard service={service} />)}
    </div>
  </div>
</section>

<style>
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  .service-icon {
    width: 56px;
    height: 56px;
    border-radius: var(--radius-lg);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-5);
    color: var(--color-text-on-accent);
    position: relative;
    transition: transform var(--duration-base) var(--ease-out);
  }

  .service-icon::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    background: inherit;
    filter: blur(16px);
    opacity: 0.4;
    z-index: -1;
  }

  .service-card:hover .service-icon {
    transform: scale(1.08) rotate(-4deg);
  }

  .service-icon.chart {
    background: var(--color-accent);
  }

  .service-icon.monitor {
    background: var(--color-accent-2);
  }

  .service-icon.sparkle {
    background: var(--color-secondary);
  }

  .service-card :global(h3) {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: var(--space-3);
    letter-spacing: -0.01em;
  }

  .service-card :global(p) {
    color: var(--color-text-secondary);
    margin-bottom: var(--space-4);
    line-height: var(--leading-relaxed);
  }

  .service-features {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .service-features :global(li) {
    color: var(--color-text-secondary);
    display: flex;
    align-items: flex-start;
    gap: var(--space-2);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  .service-features :global(li::before) {
    content: '';
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    margin-top: 0.5em;
    border-radius: 50%;
    background: var(--color-accent);
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
