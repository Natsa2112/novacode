---
import ServiceCard from './ServiceCard.astro';
import { services } from '../config/site';
---

<section id="servicios" class="section services-section">
  <div class="container">
    <header class="section-header">
      <h2 class="section-title">Soluciones Digitales para Cada Necesidad</h2>
      <p class="section-subtitle">
        Nosotros cubrimos todos los frentes de la presencia digital. Desde el desarrollo de páginas
        web profesionales hasta campañas de marketing digital de alto impacto, nuestros servicios
        están diseñados para maximizar tu crecimiento.
      </p>
    </header>

    <div class="services-grid">
      {services.map((service, index) => <ServiceCard service={service} index={index} />)}
    </div>
  </div>
</section>

<script is:inline>
  (() => {
    if (typeof window === 'undefined') return;
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (reduce) return;
    const cards = document.querySelectorAll('.service-card');
    cards.forEach((card) => {
      card.addEventListener('mousemove', (e) => {
        const r = card.getBoundingClientRect();
        card.style.setProperty('--mx', `${e.clientX - r.left}px`);
        card.style.setProperty('--my', `${e.clientY - r.top}px`);
      });
    });
  })();
</script>

<style>
  /* ---------- Section decoration ---------- */
  .section {
    position: relative;
  }

  #servicios::before {
    content: '';
    position: absolute;
    top: 10%;
    left: -10%;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, var(--color-accent) 0%, transparent 70%);
    opacity: 0.06;
    filter: blur(80px);
    pointer-events: none;
    z-index: 0;
  }

  .section-header,
  .services-grid {
    position: relative;
    z-index: 1;
  }

  /* ---------- Grid ---------- */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-6);
  }

  @media (max-width: 1024px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }

  /* ---------- Service-specific accent tokens ---------- */
  .service-card[data-accent='chart'] {
    --accent-1: #6366f1;
    --accent-2: #06b6d4;
    --accent-soft: rgba(99, 102, 241, 0.18);
    --accent-glow: rgba(99, 102, 241, 0.45);
    --accent-tint: rgba(99, 102, 241, 0.08);
  }

  .service-card[data-accent='monitor'] {
    --accent-1: #06b6d4;
    --accent-2: #10b981;
    --accent-soft: rgba(6, 182, 212, 0.18);
    --accent-glow: rgba(6, 182, 212, 0.45);
    --accent-tint: rgba(6, 182, 212, 0.08);
  }

  .service-card[data-accent='sparkle'] {
    --accent-1: #ec4899;
    --accent-2: #f59e0b;
    --accent-soft: rgba(236, 72, 153, 0.18);
    --accent-glow: rgba(236, 72, 153, 0.45);
    --accent-tint: rgba(236, 72, 153, 0.08);
  }

  /* ---------- Card base ---------- */
  :global(.service-card) {
    position: relative;
    padding: var(--space-7) var(--space-7) var(--space-6);
    display: flex;
    flex-direction: column;
    background: linear-gradient(180deg, var(--color-bg-surface) 0%, var(--color-bg-base) 100%);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-xl);
    overflow: hidden;
    isolation: isolate;
    transition:
      transform var(--duration-slow) var(--ease-out),
      border-color var(--duration-slow) var(--ease-out),
      box-shadow var(--duration-slow) var(--ease-out);
  }

  /* radial mouse-following glow */
  :global(.service-card::after) {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(
      500px circle at var(--mx, 50%) var(--my, 0%),
      var(--accent-tint),
      transparent 45%
    );
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-out);
    pointer-events: none;
    z-index: 0;
  }

  :global(.service-card:hover) {
    transform: translateY(-6px);
    border-color: transparent;
    box-shadow:
      0 24px 48px -16px rgba(0, 0, 0, 0.5),
      0 0 0 1px var(--accent-1);
  }

  :global(.service-card:hover::after) {
    opacity: 1;
  }

  /* ---------- Gradient border ---------- */
  :global(.service-card__border) {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    padding: 1px;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    -webkit-mask:
      linear-gradient(#fff 0 0) content-box,
      linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
    pointer-events: none;
    z-index: 1;
  }

  :global(.service-card:hover .service-card__border) {
    opacity: 0.9;
  }

  /* ---------- Background grid pattern ---------- */
  :global(.service-card__grid) {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(var(--accent-1) 1px, transparent 1px),
      linear-gradient(90deg, var(--accent-1) 1px, transparent 1px);
    background-size: 32px 32px;
    opacity: 0;
    mask-image: radial-gradient(ellipse 80% 60% at 100% 0%, #000 0%, transparent 70%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 100% 0%, #000 0%, transparent 70%);
    transition: opacity var(--duration-slow) var(--ease-out);
    pointer-events: none;
    z-index: 0;
  }

  :global(.service-card:hover .service-card__grid) {
    opacity: 0.06;
  }

  /* ---------- Shine scan line ---------- */
  :global(.service-card__shine) {
    position: absolute;
    top: 0;
    left: -100%;
    width: 60%;
    height: 100%;
    background: linear-gradient(
      115deg,
      transparent 0%,
      rgba(255, 255, 255, 0.04) 40%,
      rgba(255, 255, 255, 0.1) 50%,
      rgba(255, 255, 255, 0.04) 60%,
      transparent 100%
    );
    transform: skewX(-20deg);
    transition: left 1s var(--ease-out);
    pointer-events: none;
    z-index: 2;
  }

  :global(.service-card:hover .service-card__shine) {
    left: 140%;
    transition: left 1.2s var(--ease-out);
  }

  /* ---------- Corner brackets ---------- */
  :global(.service-card__bracket) {
    position: absolute;
    width: 14px;
    height: 14px;
    border: 1.5px solid var(--accent-1);
    opacity: 0.4;
    transition: opacity var(--duration-base) var(--ease-out);
    pointer-events: none;
    z-index: 3;
  }

  :global(.service-card__bracket--tl) {
    top: 10px;
    left: 10px;
    border-right: none;
    border-bottom: none;
  }

  :global(.service-card__bracket--br) {
    bottom: 10px;
    right: 10px;
    border-left: none;
    border-top: none;
  }

  :global(.service-card:hover .service-card__bracket) {
    opacity: 0.9;
  }

  /* ---------- Header ---------- */
  :global(.service-card__head) {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: var(--space-6);
    position: relative;
    z-index: 2;
  }

  :global(.service-card__icon) {
    position: relative;
    width: 64px;
    height: 64px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: var(--radius-lg);
    color: #fff;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    box-shadow:
      0 10px 24px -8px var(--accent-glow),
      inset 0 1px 0 rgba(255, 255, 255, 0.25),
      inset 0 -2px 4px rgba(0, 0, 0, 0.15);
    transition:
      transform var(--duration-slow) var(--ease-spring),
      box-shadow var(--duration-base) var(--ease-out);
  }

  /* icon glow halo (idle subtle, hover stronger) */
  :global(.service-card__icon-glow) {
    position: absolute;
    inset: -6px;
    border-radius: inherit;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    filter: blur(14px);
    opacity: 0.3;
    transition: opacity var(--duration-base) var(--ease-out);
    z-index: -1;
  }

  /* pulse ring */
  :global(.service-card__pulse) {
    position: absolute;
    inset: 0;
    border-radius: inherit;
    border: 1.5px solid var(--accent-1);
    opacity: 0;
  }

  :global(.service-card:hover .service-card__icon) {
    transform: scale(1.06) rotate(-4deg);
    box-shadow:
      0 16px 36px -8px var(--accent-glow),
      inset 0 1px 0 rgba(255, 255, 255, 0.35),
      inset 0 -2px 4px rgba(0, 0, 0, 0.15);
  }

  :global(.service-card:hover .service-card__icon-glow) {
    opacity: 0.6;
  }

  :global(.service-card:hover .service-card__pulse) {
    animation: service-pulse 1.6s var(--ease-out) infinite;
  }

  @keyframes service-pulse {
    0% {
      transform: scale(1);
      opacity: 0.8;
    }
    100% {
      transform: scale(1.4);
      opacity: 0;
    }
  }

  :global(.service-card__number) {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 600;
    letter-spacing: 0.15em;
    color: var(--color-text-tertiary);
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-full);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
    text-transform: uppercase;
  }

  :global(.service-card__number-dot) {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent-1);
    box-shadow: 0 0 8px var(--accent-1);
  }

  /* ---------- Typography ---------- */
  :global(.service-card__title) {
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--color-text-primary);
    margin: 0 0 var(--space-3);
    letter-spacing: -0.02em;
    line-height: 1.2;
    position: relative;
    z-index: 2;
  }

  :global(.service-card__desc) {
    color: var(--color-text-secondary);
    line-height: var(--leading-relaxed);
    margin: 0;
    font-size: var(--text-base);
    position: relative;
    z-index: 2;
  }

  /* ---------- Divider with glyph ---------- */
  :global(.service-card__divider) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    margin: var(--space-6) 0;
    position: relative;
    z-index: 2;
  }

  :global(.service-card__divider-line) {
    flex: 1;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--color-border-subtle) 30%,
      var(--accent-1) 100%
    );
    opacity: 0.6;
  }

  :global(.service-card__divider-glyph) {
    color: var(--accent-1);
    font-size: 8px;
    opacity: 0.7;
  }

  /* ---------- Features ---------- */
  :global(.service-card__features) {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    flex: 1;
    position: relative;
    z-index: 2;
  }

  :global(.service-card__features li) {
    display: flex;
    align-items: flex-start;
    gap: var(--space-3);
    color: var(--color-text-secondary);
    font-size: var(--text-sm);
    line-height: var(--leading-snug);
  }

  :global(.service-card__check) {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--accent-1);
    background: var(--accent-soft);
    border: 1px solid transparent;
    transition:
      transform var(--duration-base) var(--ease-spring),
      background var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
  }

  :global(.service-card__check svg) {
    width: 12px;
    height: 12px;
  }

  :global(.service-card:hover .service-card__check) {
    transform: scale(1.1);
    background: var(--color-bg-elevated);
    border-color: var(--accent-1);
  }

  /* ---------- CTA ---------- */
  :global(.service-card__cta) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-3);
    padding: var(--space-3) var(--space-4);
    border-radius: var(--radius-md);
    background: var(--color-bg-elevated);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-primary);
    text-decoration: none;
    font-size: var(--text-sm);
    font-weight: 600;
    letter-spacing: -0.01em;
    position: relative;
    z-index: 2;
    overflow: hidden;
    transition:
      color var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out);
  }

  :global(.service-card__cta::before) {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, var(--accent-1), var(--accent-2));
    opacity: 0;
    transition: opacity var(--duration-base) var(--ease-out);
    z-index: -1;
  }

  :global(.service-card__cta-arrow) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    background: var(--color-bg-base);
    border: 1px solid var(--color-border-subtle);
    color: var(--color-text-primary);
    transition:
      transform var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out),
      color var(--duration-base) var(--ease-out);
  }

  :global(.service-card__cta-arrow svg) {
    width: 14px;
    height: 14px;
  }

  :global(.service-card:hover .service-card__cta) {
    color: #fff;
    border-color: transparent;
  }

  :global(.service-card:hover .service-card__cta::before) {
    opacity: 1;
  }

  :global(.service-card:hover .service-card__cta-arrow) {
    background: rgba(255, 255, 255, 0.2);
    color: #fff;
    transform: translateX(3px);
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.service-card),
    :global(.service-card *),
    :global(.service-card::after),
    :global(.service-card__border),
    :global(.service-card__grid),
    :global(.service-card__shine),
    :global(.service-card__bracket),
    :global(.service-card__icon),
    :global(.service-card__icon-glow),
    :global(.service-card__pulse),
    :global(.service-card__check),
    :global(.service-card__cta),
    :global(.service-card__cta::before),
    :global(.service-card__cta-arrow) {
      transition: none;
      animation: none;
    }
    :global(.service-card:hover) {
      transform: none;
    }
  }
</style>
