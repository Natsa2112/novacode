---
import type { IconName } from '../types';

interface Props {
  name: IconName;
  size?: number;
  strokeWidth?: number;
  class?: string;
  label?: string;
}

const { name, size = 24, strokeWidth = 2, class: className, label } = Astro.props;

const PATHS: Record<IconName, string> = {
  facebook:
    '<path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>',
  twitter: '<path d="M4 4l16 16"/><path d="M20 4L4 20"/>',
  instagram:
    '<rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>',
  linkedin:
    '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  chart: '<path d="M12 20V10"/><path d="M18 20V4"/><path d="M6 20v-4"/>',
  monitor:
    '<rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>',
  sparkle:
    '<path d="M12 19c-7-4-6-10 0-16 6 6 7 12 0 16"/><path d="M12 3v7"/><path d="M9 9c-2-2-2-6-2-6 4 2 6 2 6 2s2-2 6-2c0 0 0 4-2 6"/><path d="M6 12c-3-1-4-4-4-4 3 1 6 1 6 1s1-3 1-6c0 0 3 1 4 4"/><path d="M18 12c3-1 4-4 4-4-3 1-6 1-6 1s-1-3-1-6c0 0-3 1-4 4"/>',
  check: '<polyline points="20 6 9 17 4 12"/>',
  'chevron-down': '<polyline points="6 9 12 15 18 9"/>',
  'arrow-right': '<line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/>',
};
---

<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width={strokeWidth}
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden={label ? 'false' : 'true'}
  aria-label={label}
  role={label ? 'img' : undefined}
  set:html={PATHS[name]}
/>
