---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title="Blog | NovaCode" description="Artículos, guías y novedades del equipo de NovaCode.">
  <main id="main-content" class="container blog-index">
    <header class="blog-header">
      <h1>Blog</h1>
      <p>Guías, novedades y casos de estudio sobre desarrollo web y marketing digital.</p>
    </header>

    {
      posts.length === 0 ? (
        <p class="blog-empty">Todavía no hay posts publicados. Vuelve pronto.</p>
      ) : (
        <ul class="blog-list">
          {posts.map((post) => (
            <li class="blog-list__item">
              <a href={`/blog/${post.id}`} class="blog-list__link">
                <time datetime={post.data.pubDate.toISOString()} class="blog-list__date">
                  {formatDate(post.data.pubDate)}
                </time>
                <h2 class="blog-list__title">{post.data.title}</h2>
                <p class="blog-list__desc">{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>

<style>
  .blog-index {
    padding: 4rem 1.25rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .blog-header {
    margin-bottom: 3rem;
  }

  .blog-header h1 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin: 0 0 0.5rem;
  }

  .blog-header p {
    color: var(--text-secondary);
    margin: 0;
  }

  .blog-empty {
    color: var(--text-secondary);
    font-style: italic;
  }

  .blog-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 1.5rem;
  }

  .blog-list__link {
    display: block;
    padding: 1.5rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.2s ease,
      background 0.2s ease,
      border-color 0.2s ease;
  }

  .blog-list__link:hover,
  .blog-list__link:focus-visible {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.07);
    border-color: var(--secondary);
  }

  .blog-list__date {
    display: block;
    font-size: 0.85rem;
    color: var(--text-secondary);
    margin-bottom: 0.5rem;
  }

  .blog-list__title {
    font-size: 1.4rem;
    margin: 0 0 0.5rem;
  }

  .blog-list__desc {
    margin: 0;
    color: var(--text-secondary);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-list__link {
      transition: none;
    }
    .blog-list__link:hover,
    .blog-list__link:focus-visible {
      transform: none;
    }
  }
</style>
