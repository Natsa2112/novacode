---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime(),
);

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title="Blog | NovaCode" description="Artículos, guías y novedades del equipo de NovaCode.">
  <main id="main-content" class="container blog-index">
    <header class="blog-header">
      <h1>Blog</h1>
      <p>Guías, novedades y casos de estudio sobre desarrollo web y marketing digital.</p>
    </header>

    {
      posts.length === 0 ? (
        <p class="blog-empty">Todavía no hay posts publicados. Vuelve pronto.</p>
      ) : (
        <ul class="blog-list">
          {posts.map((post) => (
            <li class="blog-list__item">
              <a href={`/blog/${post.id}`} class="blog-list__link">
                <time datetime={post.data.pubDate.toISOString()} class="blog-list__date">
                  {formatDate(post.data.pubDate)}
                </time>
                <h2 class="blog-list__title">{post.data.title}</h2>
                <p class="blog-list__desc">{post.data.description}</p>
              </a>
            </li>
          ))}
        </ul>
      )
    }
  </main>
</Layout>

<style>
  .blog-index {
    padding: var(--space-16) var(--space-4);
    max-width: 760px;
    margin: 0 auto;
  }

  .blog-header {
    margin-bottom: var(--space-12);
  }

  .blog-header h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 800;
    letter-spacing: -0.02em;
    margin: 0 0 var(--space-3);
    background: var(--gradient-text);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }

  .blog-header p {
    color: var(--color-text-secondary);
    margin: 0;
    font-size: var(--text-lg);
  }

  .blog-empty {
    color: var(--color-text-secondary);
    font-style: italic;
  }

  .blog-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-4);
  }

  .blog-list__link {
    display: block;
    padding: var(--space-6);
    border-radius: var(--radius-lg);
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    color: inherit;
    text-decoration: none;
    transition:
      transform var(--duration-base) var(--ease-out),
      background var(--duration-base) var(--ease-out),
      border-color var(--duration-base) var(--ease-out);
  }

  .blog-list__link:hover,
  .blog-list__link:focus-visible {
    transform: translateY(-3px);
    background: var(--color-bg-elevated);
    border-color: var(--color-accent);
  }

  .blog-list__date {
    display: block;
    font-size: var(--text-sm);
    color: var(--color-text-tertiary);
    margin-bottom: var(--space-2);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .blog-list__title {
    font-size: var(--text-xl);
    font-weight: 700;
    margin: 0 0 var(--space-2);
    letter-spacing: -0.01em;
  }

  .blog-list__desc {
    margin: 0;
    color: var(--color-text-secondary);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-list__link {
      transition: none;
    }
    .blog-list__link:hover,
    .blog-list__link:focus-visible {
      transform: none;
    }
  }
</style>
