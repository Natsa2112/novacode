---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

interface Props {
  post: CollectionEntry<'posts'>;
}

const { post } = Astro.props;
const { Content } = await render(post);

const formatDate = (date: Date) =>
  date.toLocaleDateString('es-AR', { year: 'numeric', month: 'long', day: 'numeric' });
---

<Layout title={`${post.data.title} | NovaCode`} description={post.data.description}>
  <main id="main-content" class="container blog-post">
    <a href="/blog" class="blog-post__back">← Volver al blog</a>
    <article>
      <header class="blog-post__header">
        <time datetime={post.data.pubDate.toISOString()} class="blog-post__date">
          {formatDate(post.data.pubDate)}
        </time>
        <h1 class="blog-post__title">{post.data.title}</h1>
        {post.data.description && <p class="blog-post__lead">{post.data.description}</p>}
      </header>
      <div class="blog-post__body">
        <Content />
      </div>
    </article>
  </main>
</Layout>

<style>
  .blog-post {
    padding: var(--space-16) var(--space-4);
    max-width: 720px;
    margin: 0 auto;
  }

  .blog-post__back {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-accent);
    text-decoration: none;
    margin-bottom: var(--space-8);
    font-size: var(--text-sm);
    font-weight: 500;
    transition: color var(--duration-base) var(--ease-out);
  }

  .blog-post__back:hover,
  .blog-post__back:focus-visible {
    color: var(--color-accent-hover);
  }

  .blog-post__header {
    margin-bottom: var(--space-10);
    padding-bottom: var(--space-6);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .blog-post__date {
    display: block;
    color: var(--color-text-tertiary);
    font-size: var(--text-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    margin-bottom: var(--space-3);
  }

  .blog-post__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-4xl));
    font-weight: 800;
    margin: 0 0 var(--space-4);
    line-height: var(--leading-tight);
    letter-spacing: -0.02em;
  }

  .blog-post__lead {
    color: var(--color-text-secondary);
    font-size: var(--text-lg);
    line-height: var(--leading-relaxed);
    margin: 0;
  }

  .blog-post__body :global(h2) {
    margin-top: var(--space-10);
    margin-bottom: var(--space-4);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text-primary);
  }

  .blog-post__body :global(h3) {
    margin-top: var(--space-8);
    margin-bottom: var(--space-3);
    font-size: var(--text-xl);
    font-weight: 600;
  }

  .blog-post__body :global(p),
  .blog-post__body :global(ul),
  .blog-post__body :global(ol) {
    line-height: var(--leading-relaxed);
    color: var(--color-text-primary);
    margin-bottom: var(--space-4);
  }

  .blog-post__body :global(ul),
  .blog-post__body :global(ol) {
    padding-left: var(--space-6);
  }

  .blog-post__body :global(li) {
    margin-bottom: var(--space-2);
  }

  .blog-post__body :global(a) {
    color: var(--color-accent);
    text-decoration: underline;
    text-decoration-color: var(--color-accent-soft);
    text-underline-offset: 3px;
  }

  .blog-post__body :global(a:hover) {
    color: var(--color-accent-hover);
    text-decoration-color: var(--color-accent);
  }

  .blog-post__body :global(blockquote) {
    margin: var(--space-6) 0;
    padding: var(--space-4) var(--space-6);
    border-left: 3px solid var(--color-accent);
    background: var(--color-bg-surface);
    color: var(--color-text-secondary);
    font-style: italic;
    border-radius: 0 var(--radius-md) var(--radius-md) 0;
  }

  .blog-post__body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.9em;
    padding: 0.15em 0.4em;
    background: var(--color-bg-elevated);
    border-radius: var(--radius-sm);
    color: var(--color-accent-2);
  }

  .blog-post__body :global(pre) {
    background: var(--color-bg-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    overflow-x: auto;
    margin: var(--space-6) 0;
  }

  .blog-post__body :global(pre code) {
    background: transparent;
    padding: 0;
    color: var(--color-text-primary);
  }

  @media (prefers-reduced-motion: reduce) {
    .blog-post__back {
      transition: none;
    }
  }
</style>
